# =========================================================
# Finance_Ops_Dev - Environment Example
# =========================================================
# This file is a template only.
# Do not put real passwords, real credentials, or production
# connection strings in this file.
#
# Real credential file should be named:
# .env
#
# The real .env file must stay local and must not be committed
# to GitHub.
# =========================================================


# PostgreSQL Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finance_ops_dev
POSTGRES_USER=your_username_here
POSTGRES_PASSWORD=your_password_here


# Power BI / Gateway Placeholder
POWERBI_GATEWAY_NAME=your_gateway_name_here


# Project Mode
PROJECT_ENV=development
DATA_POLICY=masked_data_only